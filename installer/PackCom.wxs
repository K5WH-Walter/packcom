<?xml version="1.0" encoding="UTF-8"?>
<!--
  PackCom.wxs  –  WiX v4 installer definition
  Produces: PackCom-<version>-x64.msi
  Installs packcom.exe to %ProgramFiles%\PackCom\
  Creates Start Menu shortcut and optional Desktop shortcut.
  Adds/removes %ProgramFiles%\PackCom from the user's PATH.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="PackCom"
    Version="0.75.0.0"
    Manufacturer="Jim Wright WB4ZJV (C++ port)"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow upgrades; remove older versions automatically -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of PackCom is already installed."
      Schedule="afterInstallInitialize" />

    <!-- Embed all files inside the MSI -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ============================================================ -->
    <!--  UI  –  WiX built-in WixUI_Minimal dialog set                       -->
    <!-- ============================================================ -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- Licence text shown in the UI -->
    <WixVariable Id="WixUILicenseRtf" Value="..\LICENSE.rtf" />

    <!-- ============================================================ -->
    <!--  Directory structure                                                 -->
    <!-- ============================================================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PackCom" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PackCom" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ============================================================ -->
    <!--  Components                                                          -->
    <!-- ============================================================ -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!-- Main executable -->
      <Component Id="MainExecutable" Guid="B1C2D3E4-F5A6-7890-BCDE-F12345678901">
        <File Id="PackComExe"
              Source="..\build\Release\packcom.exe"
              KeyPath="yes" />

        <!-- Add install dir to system PATH -->
        <Environment Id="PATH"
                     Name="PATH"
                     Value="[INSTALLFOLDER]"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
      </Component>

      <!-- Start Menu shortcut -->
      <Component Id="StartMenuShortcut"
                 Guid="C2D3E4F5-A6B7-8901-CDEF-123456789012"
                 Directory="ApplicationProgramsFolder">
        <Shortcut Id="StartMenuShortcutEntry"
                  Name="PackCom"
                  Description="Packet Radio Terminal"
                  Target="[INSTALLFOLDER]packcom.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanUpStartMenu"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\PackCom"
                       Name="StartMenuInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Desktop shortcut (optional; user can deselect in UI) -->
      <Component Id="DesktopShortcut"
                 Guid="D3E4F5A6-B7C8-9012-DEFA-234567890123"
                 Directory="DesktopFolder">
        <Shortcut Id="DesktopShortcutEntry"
                  Name="PackCom"
                  Description="Packet Radio Terminal"
                  Target="[INSTALLFOLDER]packcom.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\PackCom"
                       Name="DesktopInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <!-- ============================================================ -->
    <!--  Feature tree                                                        -->
    <!-- ============================================================ -->
    <Feature Id="ProductFeature"
             Title="PackCom"
             Level="1"
             Description="Packet Radio Terminal application">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

  </Package>
</Wix>
